# Files and folders git should NOT track

# Node.js dependencies (installed packages — too large to upload, rebuilt from package.json)
node_modules/

# System files
.DS_Store
Thumbs.db

# Editor files
.vscode/
*.swp

# Claude Code internal state (worktrees, local settings)
.claude/

# Environment variables (never commit secrets)
.env
.env.local

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
